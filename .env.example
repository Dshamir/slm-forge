# SLM-Forge environment configuration template.
# Copy to .env and fill in your values. NEVER commit your actual .env.

# === Required ===

# Anthropic API key (synth + plan-fit grading + smoketest validator).
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# HuggingFace write token (register + publish phases).
# https://huggingface.co/settings/tokens — role: write.
HF_TOKEN=

# AWS credentials (provision + train + bootstrap + monitor + teardown).
# Scope to least-privilege; see scripts/setup-aws.sh for an example policy.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ca-central-1

# CAS bucket + KMS key (must exist + be encrypted with this KMS alias).
FORGE_BUCKET=
FORGE_KMS_ALIAS=alias/your-cas-key
FORGE_AWS_ACCOUNT_ID=
FORGE_PREFIX=forge

# === Optional ===

# AWS profile (if you use named profiles instead of env keys).
# FORGE_AWS_PROFILE=your-iam-user

# Skip OCR plugin (figures with little useful text).
# FORGE_DISABLE_OCR=1

# MP4 whitelist filter — skip clips shorter than this many seconds.
# FORGE_VIDEO_MIN_DURATION_SEC=120

# MP4 whitelist filter — require audio stream.
# FORGE_VIDEO_REQUIRE_AUDIO=1

# Train calibration burst — abort if sec/step exceeds threshold during steps 20..N.
# FORGE_CALIBRATION_STEPS=100
# FORGE_CALIBRATION_MAX_SEC_PER_STEP=27

# Register phase overrides.
# FORGE_REGISTER_NAMESPACE=your-hf-namespace
# FORGE_REGISTER_NAME_PREFIX=
# FORGE_REGISTER_SKIP_SPACE=1
# FORGE_REGISTER_PUBLIC=1
